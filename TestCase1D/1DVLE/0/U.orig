FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (1 0 0);

boundaryField
{
    // Wände

    rechts
    {
    type  cyclic;

    }   
    links
    {
    type  cyclic;
    }

    top
    {
        type        zeroGradient;
    }
    bottom
    {
        type        zeroGradient;
    }

    // 2D-Rand (z-Richtung)
    front
    {
        type        empty;
    }
    back
    {
        type        empty;
    }
}    



// ************************************************************************* //
